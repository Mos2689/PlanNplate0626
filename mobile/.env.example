# PnP Mobile App Environment Variables Example
# Copy this file to '.env' and fill in your actual values.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

OPENAI_API_KEY=your-openai-api-key
EXPO_PUBLIC_PEXELS_API_KEY=your-pexels-api-key
EXPO_PUBLIC_RESEND_API_KEY=your-resend-api-key
EXPO_PUBLIC_VIBECODE_GOOGLE_API_KEY=your-google-api-key
EXPO_PUBLIC_Maps_API_Key=your-google-maps-api-key

# RevenueCat keys (if using subscriptions)
EXPO_PUBLIC_VIBECODE_REVENUECAT_APPLE_KEY=your-revenuecat-apple-key
EXPO_PUBLIC_VIBECODE_REVENUECAT_GOOGLE_KEY=your-revenuecat-google-key
EXPO_PUBLIC_VIBECODE_REVENUECAT_TEST_KEY=your-revenuecat-test-key

# Meta/Facebook SDK Credentials (for App Install / conversion tracking)
EXPO_PUBLIC_META_APP_ID=your-meta-app-id
EXPO_PUBLIC_META_CLIENT_TOKEN=your-meta-client-token
EXPO_PUBLIC_META_DISPLAY_NAME=PlanNplate

